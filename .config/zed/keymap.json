[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-v": "editor::Paste",
      "ctrl-x": "editor::Cut",
      "ctrl-d": "editor::DuplicateLineDown",
      "ctrl-c": "editor::Copy",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-alt-b": "workspace::ToggleRightDock",
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-`": "terminal_panel::ToggleFocus",
      "ctrl-1": "workspace::ActivatePaneLeft",
      "ctrl-2": "workspace::ActivatePaneRight",
      "ctrl-3": "workspace::ActivatePaneUp",
      "ctrl-4": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-`": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-j": "workspace::ToggleBottomDock"
    }
  }
]
